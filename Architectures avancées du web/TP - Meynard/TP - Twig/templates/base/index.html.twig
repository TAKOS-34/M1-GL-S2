{% extends 'base.html.twig' %}

{% block title %}Twig{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div>
    <h1>Calcul de n</h1>
    <form>
        <input type="number" name="facto" placeholder="n" />
        <input type="submit" />
    </form>

    <h1>Calcul des combinaisons de n éléments dans p place</h1>
    <form>
        <input type="number" name="n_combi" placeholder="n" />
        <input type="number" name="p_combi" placeholder="p" />
        <input type="submit" />
    </form>

    {% if p_combi is defined and n_combi is defined %}
        <h1>Résultat</h1>
        Combinatoire ({{ n_combi }}, {{ p_combi }}) = {{ res }}

    {% elseif n_facto is defined %}
        <h1>Résultat</h1>
        Factorielle de {{ n_facto }} = {{ res }}

    {% endif %}
</div>
{% endblock %}
