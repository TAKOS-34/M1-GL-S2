{% extends 'base.html.twig' %}

{% block title %}Tournois{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
    <h1>Tournois</h1>

    <ul>
        {% for e in evt %}
            <li><b>{{ e.nom }}</b>{% if e.description %} | {{ e.description }} {% endif %}</li>
            <ul>
                {% for t in e.tournoisList %}
                    <li><b>{{ t.nom }}</b> | <i>{{ t.dateDeb|date('d/m/Y') }}| {{ t.dateFin|date('d/m/Y') }}</i></li>
                {% endfor %}
            </ul>
        {% endfor %}
    </ul>
</div>
{% endblock %}
